<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>WeatherNow — Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#0d1117; --bg2:#161b22; --card:#1c2333; --border:#30363d; --accent:#2ea8e0; --amber:#d29922; --green:#3fb950; --orange:#f0883e; --red:#f85149; --text:#e6edf3; --soft:#8b949e; --muted:#484f58; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg); color: var(--text); min-height: 100vh;
      background-image: radial-gradient(600px 400px at 80% 10%, rgba(210,153,34,0.07) 0%, transparent 55%);
    }

    nav { position: sticky; top: 0; z-index: 200; display: flex; justify-content: space-between; align-items: center; padding: 0 2rem; height: 60px; background: rgba(13,17,23,0.9); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
    .nav-left { display: flex; align-items: center; gap: 0.6rem; }
    .nav-logo { font-size: 1.1rem; font-weight: 800; color: var(--amber); text-decoration: none; }
    .admin-pill { font-size: 0.68rem; font-weight: 700; background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.2); color: var(--amber); padding: 0.18rem 0.6rem; border-radius: 20px; letter-spacing: 1px; text-transform: uppercase; }
    .nav-right { display: flex; align-items: center; gap: 0.75rem; }
    .nav-who { font-size: 0.82rem; color: var(--soft); }
    .nav-who span { color: var(--amber); font-weight: 600; }
    .nav-btn { font-size: 0.82rem; font-weight: 600; text-decoration: none; padding: 0.35rem 0.9rem; border-radius: 20px; border: 1px solid rgba(248,81,73,0.3); color: var(--red); background: rgba(248,81,73,0.06); transition: all 0.2s; }
    .nav-btn:hover { background: rgba(248,81,73,0.12); }

    .container { max-width: 1040px; margin: 0 auto; padding: 2.5rem 1.2rem; }
    .page-head { margin-bottom: 2rem; }
    .page-head h1 { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 0.3rem; }
    .page-head p { color: var(--soft); font-size: 0.88rem; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 0.75rem; margin-bottom: 2rem; }
    .stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.2rem; text-align: center; transition: border-color 0.2s, transform 0.2s; animation: up 0.5s ease both; }
    .stat-card:hover { transform: translateY(-3px); border-color: var(--amber); }
    @keyframes up { from{opacity:0;transform:translateY(12px);} to{opacity:1;transform:translateY(0);} }
    .s-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }
    .s-label { font-size: 0.67rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 0.3rem; }
    .s-val { font-size: 2rem; font-weight: 800; }
    .s-val.amber  { color: var(--amber); }
    .s-val.accent { color: var(--accent); }
    .s-val.green  { color: var(--green); font-size: 1rem; }
    .s-sub { color: var(--muted); font-size: 0.7rem; margin-top: 0.15rem; }

    .section-label { font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.7rem; }

    .table-box { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead { border-bottom: 1px solid var(--border); }
    th { text-align: left; padding: 0.85rem 1.1rem; font-size: 0.67rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); }
    tbody tr { border-bottom: 1px solid rgba(48,54,61,0.6); transition: background 0.15s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(46,168,224,0.03); }
    td { padding: 0.9rem 1.1rem; font-size: 0.88rem; vertical-align: middle; }
    .u-name { font-weight: 700; font-size: 0.95rem; }
    .u-email { color: var(--muted); font-size: 0.75rem; margin-top: 2px; }
    .count-pill { display: inline-block; background: rgba(46,168,224,0.1); border: 1px solid rgba(46,168,224,0.2); color: var(--accent); font-weight: 700; padding: 0.18rem 0.7rem; border-radius: 20px; font-size: 0.85rem; }
    .t-hot  { color: var(--orange); font-weight: 600; font-size: 0.85rem; }
    .t-cold { color: #a78bfa; font-weight: 600; font-size: 0.85rem; }
    .t-na   { color: var(--muted); font-size: 0.82rem; }
    .t-time { color: var(--muted); font-size: 0.78rem; }
    .view-btn { display: inline-block; background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.2); color: var(--amber); padding: 0.28rem 0.8rem; border-radius: 20px; text-decoration: none; font-size: 0.78rem; font-weight: 600; transition: all 0.2s; }
    .view-btn:hover { background: rgba(210,153,34,0.2); }

    .no-data { text-align: center; padding: 3rem; color: var(--muted); font-size: 0.9rem; }
    @media(max-width:600px) { nav{padding:0 1rem;} .container{padding:1.5rem 1rem;} }
  </style>
</head>
<body>
<nav>
  <div class="nav-left">
    <a href="/admin" class="nav-logo">🔐 WeatherNow</a>
    <span class="admin-pill">Admin</span>
  </div>
  <div class="nav-right">
    <span class="nav-who">Signed in as <span><%= adminName %></span></span>
    <a href="/admin/logout" class="nav-btn">Sign out</a>
  </div>
</nav>

<div class="container">
  <div class="page-head">
    <h1>🛠️ Admin Dashboard</h1>
    <p>Full overview of all users and their activity on WeatherNow.</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card" style="animation-delay:0s">
      <div class="s-icon">👥</div><div class="s-label">Total Users</div>
      <div class="s-val amber"><%= totalUsers %></div><div class="s-sub">registered accounts</div>
    </div>
    <div class="stat-card" style="animation-delay:0.08s">
      <div class="s-icon">🔍</div><div class="s-label">Total Searches</div>
      <div class="s-val accent"><%= totalSearches %></div><div class="s-sub">across all users</div>
    </div>
    <div class="stat-card" style="animation-delay:0.16s">
      <div class="s-icon">🏆</div><div class="s-label">Most Active</div>
      <% if (mostActive) { %>
        <div class="s-val green"><%= mostActive.name %></div>
        <div class="s-sub"><%= mostActive.search_count %> searches</div>
      <% } else { %>
        <div class="s-val green">—</div><div class="s-sub">no data yet</div>
      <% } %>
    </div>
  </div>

  <div class="section-label">All Registered Users</div>
  <% if (users && users.length > 0) { %>
  <div class="table-box">
    <table>
      <thead>
        <tr>
          <th>#</th><th>User</th><th>Searches</th>
          <th>Hottest</th><th>Coldest</th><th>Last Active</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(user, i) { %>
        <tr>
          <td style="color:var(--muted);font-size:0.8rem">#<%= i+1 %></td>
          <td>
            <div class="u-name">👤 <%= user.name %></div>
            <div class="u-email"><%= user.email %></div>
          </td>
          <td><span class="count-pill"><%= user.search_count %></span></td>
          <td><% if (user.hottest != null) { %><span class="t-hot">🔥 <%= user.hottest %>°C</span><% } else { %><span class="t-na">—</span><% } %></td>
          <td><% if (user.coldest != null) { %><span class="t-cold">🧊 <%= user.coldest %>°C</span><% } else { %><span class="t-na">—</span><% } %></td>
          <td><span class="t-time"><%= user.last_search ? new Date(user.last_search).toLocaleString() : 'Never' %></span></td>
          <td><a href="/admin/user/<%= user.id %>" class="view-btn">View →</a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="no-data">No users registered yet.</div>
  <% } %>
</div>
</body>
</html>
