<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>WeatherNow — Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#0d1117; --card:#1c2333; --border:#30363d; --accent:#2ea8e0; --accent2:#1d8fc9; --red:#f85149; --text:#e6edf3; --soft:#8b949e; --muted:#484f58; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg); color: var(--text);
      min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
      background-image:
        radial-gradient(600px 400px at 70% 0%, rgba(46,168,224,0.07) 0%, transparent 60%),
        radial-gradient(500px 400px at 10% 100%, rgba(124,92,191,0.07) 0%, transparent 60%);
    }
    .brand { display: flex; align-items: center; gap: 0.5rem; font-size: 1.1rem; font-weight: 800; color: var(--accent); margin-bottom: 1.5rem; animation: up 0.5s ease both; }
    .brand span { font-size: 1.4rem; animation: float 3s ease-in-out infinite; }
    @keyframes float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-4px);} }
    @keyframes up { from{opacity:0;transform:translateY(14px);} to{opacity:1;transform:translateY(0);} }

    .card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 16px; padding: 2.2rem 2rem; width: 100%; max-width: 400px;
      animation: up 0.5s ease 0.05s both;
    }
    h2 { font-size: 1.4rem; font-weight: 800; margin-bottom: 0.25rem; }
    .sub { color: var(--soft); font-size: 0.85rem; margin-bottom: 1.8rem; }

    .err { background: rgba(248,81,73,0.08); border: 1px solid rgba(248,81,73,0.25); border-radius: 10px; padding: 0.7rem 1rem; color: #ff9492; font-size: 0.85rem; margin-bottom: 1.2rem; text-align: center; }

    .field { margin-bottom: 1rem; }
    label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--soft); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.8px; }
    input { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 0.8rem 1rem; color: var(--text); font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.93rem; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
    input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(46,168,224,0.1); }
    input::placeholder { color: var(--muted); }

    .btn { width: 100%; background: var(--accent); color: #fff; border: none; padding: 0.85rem; border-radius: 10px; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.95rem; cursor: pointer; margin-top: 0.5rem; transition: background 0.2s, transform 0.15s; }
    .btn:hover { background: var(--accent2); transform: translateY(-1px); }

    .divider { display: flex; align-items: center; gap: 0.8rem; margin: 1.3rem 0; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .divider span { color: var(--muted); font-size: 0.75rem; }

    .footer { text-align: center; color: var(--soft); font-size: 0.85rem; }
    .footer a { color: var(--accent); text-decoration: none; font-weight: 600; }
    .footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>
<div class="brand"><span>⛅</span> WeatherNow</div>
<div class="card">
  <h2>Welcome back 👋</h2>
  <p class="sub">Sign in to access your weather dashboard</p>

  <% if (error) { %><div class="err">⚠️ <%= error %></div><% } %>

  <form method="POST" action="/login">
    <div class="field">
      <label>Email</label>
      <input type="email" name="email" placeholder="you@example.com" required autofocus/>
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" name="password" placeholder="••••••••" required/>
    </div>
    <button class="btn" type="submit">Sign in →</button>
  </form>

  <div class="divider"><span>or</span></div>
  <div class="footer">No account? <a href="/signup">Create one free</a></div>
</div>
</body>
</html>
