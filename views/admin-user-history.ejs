<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>WeatherNow — User History</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#0d1117; --bg2:#161b22; --card:#1c2333; --border:#30363d; --accent:#2ea8e0; --amber:#d29922; --green:#3fb950; --orange:#f0883e; --red:#f85149; --purple:#7c5cbf; --text:#e6edf3; --soft:#8b949e; --muted:#484f58; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg); color: var(--text); min-height: 100vh;
      background-image: radial-gradient(600px 400px at 80% 10%, rgba(210,153,34,0.07) 0%, transparent 55%);
    }

    nav { position: sticky; top: 0; z-index: 200; display: flex; justify-content: space-between; align-items: center; padding: 0 2rem; height: 60px; background: rgba(13,17,23,0.9); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
    .nav-left { display: flex; align-items: center; gap: 0.6rem; }
    .nav-logo { font-size: 1.1rem; font-weight: 800; color: var(--amber); text-decoration: none; }
    .admin-pill { font-size: 0.68rem; font-weight: 700; background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.2); color: var(--amber); padding: 0.18rem 0.6rem; border-radius: 20px; letter-spacing: 1px; text-transform: uppercase; }
    .nav-right { display: flex; align-items: center; gap: 0.75rem; }
    .nav-btn { font-size: 0.82rem; font-weight: 600; text-decoration: none; padding: 0.35rem 0.9rem; border-radius: 20px; border: 1px solid var(--border); color: var(--soft); background: var(--bg2); transition: all 0.2s; }
    .nav-btn:hover { border-color: var(--accent); color: var(--accent); }
    .nav-btn.logout { border-color: rgba(248,81,73,0.3); color: var(--red); background: rgba(248,81,73,0.06); }

    .container { max-width: 860px; margin: 0 auto; padding: 2.5rem 1.2rem; }
    .back { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--soft); text-decoration: none; font-size: 0.85rem; margin-bottom: 1.8rem; transition: color 0.2s; }
    .back:hover { color: var(--amber); }

    .page-head { margin-bottom: 2rem; }
    .page-head h1 { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 0.3rem; }
    .page-head h1 span { color: var(--amber); }
    .page-head p { color: var(--soft); font-size: 0.88rem; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px,1fr)); gap: 0.75rem; margin-bottom: 2rem; }
    .stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.2rem; text-align: center; transition: border-color 0.2s, transform 0.2s; animation: up 0.5s ease both; }
    .stat-card:hover { transform: translateY(-3px); border-color: var(--amber); }
    @keyframes up { from{opacity:0;transform:translateY(12px);} to{opacity:1;transform:translateY(0);} }
    .s-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }
    .s-label { font-size: 0.67rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 0.3rem; }
    .s-val { font-size: 1.9rem; font-weight: 800; }
    .s-val.amber  { color: var(--amber); }
    .s-val.green  { color: var(--green); font-size: 1rem; }
    .s-val.orange { color: var(--orange); }
    .s-val.purple { color: #a78bfa; }
    .s-sub { color: var(--muted); font-size: 0.7rem; margin-top: 0.15rem; }

    .section-label { font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.7rem; }

    .history-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .h-row { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.3rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; transition: border-color 0.2s, transform 0.2s; animation: up 0.4s ease both; }
    .h-row:hover { border-color: var(--amber); transform: translateX(4px); }
    .h-left { display: flex; align-items: center; gap: 0.9rem; }
    .h-num { font-size: 0.78rem; font-weight: 700; color: var(--muted); min-width: 26px; }
    .h-city { font-size: 1rem; font-weight: 700; }
    .h-time { color: var(--muted); font-size: 0.75rem; margin-top: 2px; }
    .h-right { display: flex; align-items: center; gap: 0.75rem; }
    .h-temp { font-size: 1.5rem; font-weight: 800; color: var(--accent); }
    .badge { font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.65rem; border-radius: 20px; border: 1px solid transparent; }
    .badge-hot  { background:rgba(240,136,62,0.1); border-color:rgba(240,136,62,0.25); color:var(--orange); }
    .badge-warm { background:rgba(63,185,80,0.1);  border-color:rgba(63,185,80,0.25);  color:var(--green); }
    .badge-cool { background:rgba(46,168,224,0.1); border-color:rgba(46,168,224,0.25); color:var(--accent); }
    .badge-cold { background:rgba(124,92,191,0.1); border-color:rgba(124,92,191,0.25); color:#a78bfa; }

    .empty { text-align: center; padding: 4rem; color: var(--muted); font-size: 0.9rem; font-weight: 400; }
    @media(max-width:600px) { nav{padding:0 1rem;} .container{padding:1.5rem 1rem;} }
  </style>
</head>
<body>
<nav>
  <div class="nav-left">
    <a href="/admin" class="nav-logo">🔐 WeatherNow</a>
    <span class="admin-pill">Admin</span>
  </div>
  <div class="nav-right">
    <a href="/admin" class="nav-btn">← Dashboard</a>
    <a href="/admin/logout" class="nav-btn logout">Sign out</a>
  </div>
</nav>

<div class="container">
  <a href="/admin" class="back">← Back to Dashboard</a>

  <div class="page-head">
    <h1>👤 <span><%= userName %></span>'s History</h1>
    <p>Full search record for this user.</p>
  </div>

  <% if (total > 0) { %>
  <div class="stats-grid">
    <div class="stat-card" style="animation-delay:0s">
      <div class="s-icon">🔍</div><div class="s-label">Total Searches</div>
      <div class="s-val amber"><%= total %></div><div class="s-sub">all time</div>
    </div>
    <div class="stat-card" style="animation-delay:0.07s">
      <div class="s-icon">🏆</div><div class="s-label">Most Searched</div>
      <div class="s-val green"><%= topCity %></div><div class="s-sub">favourite city</div>
    </div>
    <div class="stat-card" style="animation-delay:0.14s">
      <div class="s-icon">🔥</div><div class="s-label">Hottest</div>
      <div class="s-val orange"><%= maxTemp %>°C</div><div class="s-sub">highest recorded</div>
    </div>
    <div class="stat-card" style="animation-delay:0.21s">
      <div class="s-icon">🧊</div><div class="s-label">Coldest</div>
      <div class="s-val purple"><%= minTemp %>°C</div><div class="s-sub">lowest recorded</div>
    </div>
  </div>

  <div class="section-label">Search Records</div>
  <div class="history-list">
    <% history.forEach(function(item, i) {
      var t = Number(item.temperature);
      var bc = 'badge-cold', bl = '❄️ Cold';
      if (t > 30)      { bc='badge-hot';  bl='🔥 Hot'; }
      else if (t > 20) { bc='badge-warm'; bl='😎 Warm'; }
      else if (t > 10) { bc='badge-cool'; bl='🧥 Cool'; }
    %>
    <div class="h-row" style="animation-delay:<%= i * 0.035 %>s">
      <div class="h-left">
        <div class="h-num">#<%= i+1 %></div>
        <div>
          <div class="h-city">📍 <%= item.city %></div>
          <div class="h-time"><%= item.searched_at ? new Date(item.searched_at).toLocaleString() : 'Recently' %></div>
        </div>
      </div>
      <div class="h-right">
        <span class="badge <%= bc %>"><%= bl %></span>
        <div class="h-temp"><%= t %>°</div>
      </div>
    </div>
    <% }); %>
  </div>

  <% } else { %>
  <div class="empty">This user has no searches yet.</div>
  <% } %>
</div>
</body>
</html>
